# Airtable Configuration
# Get your access token from: https://airtable.com/create/tokens
AIRTABLE_ACCESS_TOKEN=your_airtable_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here

# NewsData.io Configuration
# Get your API key from: https://newsdata.io/
NEWS_DATA_KEY=your_newsdata_api_key_here

# TheNewsAPI.com Configuration
# Get your API key from: https://www.thenewsapi.com/
THE_NEWS_API_KEY=your_thenewsapi_key_here

# OpenAI API Configuration (optional)
# Get your API key from: https://platform.openai.com/api-keys
#OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude) API Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_PROVIDER=claude
